            arr[i] = str.charAt(i) - '0';
        }
        System.out.print("Array: ");
        for (int i = 0; i < arr.length; i++) {
            System.out.print(arr[i] + " ");
        }
    }
}

//INT TO STRING, STRING TO CHAR,CHAR TO ARRAY TO FIND THE LARGEST NO

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int num = sc.nextInt();
        String str = String.valueOf(num);
        char[] ch = str.toCharArray();
        int[] arr = new int[ch.length];
        for (int i = 0; i < ch.length; i++) {
            arr[i] = ch[i] - '0';
        }
        int max = arr[0];
        for (int i = 1; i < arr.length; i++) {
            if (arr[i] > max) {
                max = arr[i];
            }
        }
        System.out.println("Largest digit = " + max);
    }
}

// 1947 show that 9 is maximun num

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int num = sc.nextInt();
        String str = String.valueOf(num);
        System.out.println("String: " + str);
        char[] ch = str.toCharArray();
        System.out.print("Char Array: ");
        for (char c : ch) {
            System.out.print(c + " ");
        }
        int[] arr = new int[ch.length];
        int max = 0;
        System.out.print("\nArray: ");
        for (int i = 0; i < ch.length; i++) {
            arr[i] = ch[i] - '0';
            System.out.print(arr[i] + " ");
            if (arr[i] > max) {
                max = arr[i];
            }
        }
        System.out.println("\nLargest Digit: " + max);
    }
}

//repeated value

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[] arr = new int[5];
        System.out.println("Enter elements:");
        for (int i = 0; i < 5; i++) {
            arr[i] = sc.nextInt();
        }
        for (int i = 0; i < 5; i++) {
            for (int j = i + 1; j < 5; j++) {
                if (arr[i] == arr[j]) {
                    System.out.println("Repeated value is " + arr[i]);
                    return;
                }
            }
        }

        System.out.println("No repeated value");
    }
}

//repeated value using sort 

import java.util.Scanner;
import java.util.Arrays;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter number of elements: ");
        int n = sc.nextInt();
        int[] arr = new int[n];
        System.out.println("Enter array elements:");
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        Arrays.sort(arr);
        System.out.println("Repeated values are:");
        for (int i = 0; i < n - 1; i++) {
            if (arr[i] == arr[i + 1]) {
                System.out.println(arr[i]);
            }
        }
    }
}

//remove duplicate and concatenate the remaining value

import java.util.Scanner;
import java.util.Arrays;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter array size: ");
        int n = sc.nextInt();
        int arr[] = new int[n];
        System.out.println("Enter array elements:");
        for(int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        Arrays.sort(arr);
        String result = "";
        for(int i = 0; i < n; i++) {
            if(i == 0 || arr[i] != arr[i - 1]) {
                result = result + arr[i];
            }
        }
        System.out.println("After removing duplicates and concatenating:");
        System.out.println(result);
    }
}

//SUM THE GIVEN ARRAY IT'S EQUAL TO TARGET VALUE

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[] arr = new int[5];
        System.out.println("Enter 5 array elements:");
        for (int i = 0; i < 5; i++) {
            arr[i] = sc.nextInt();
        }
        System.out.print("Enter target value: ");
        int target = sc.nextInt();
        boolean found = false;
        for (int i = 0; i < arr.length - 1; i++) {
            int sum = arr[i] + arr[i + 1];
            if (sum == target) {
                found = true;
                break;
            }
        }
        if (found)
            System.out.println("Valid");
        else
            System.out.println("Invalid");

        sc.close();
    }
}

//TO CHECK TARGET VALUE WITH 2 ARRAY

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[] arr = new int[5];
        System.out.println("Enter an array:");
        for (int i = 0; i < 5; i++) {
            arr[i] = sc.nextInt();
        }
        System.out.print("Enter target value: ");
        int target = sc.nextInt();
        boolean found = false;
        for (int i = 0; i < 5; i++) {
            for (int j = i + 1; j < 5; j++) {
                if (arr[i] + arr[j] == target) {
                    found = true;
                }
            }
        }
        for (int i = 0; i < 5 && !found; i++) {
            for (int j = i + 1; j < 5 && !found; j++) {
                for (int k = j + 1; k < 5; k++) {
                    if (arr[i] + arr[j] + arr[k] == target) {
                        found = true;
                        break;
                    }
                }
            }
        }
        if (found)
            System.out.println("Valid");
        else
            System.out.println("Invalid");
    }
}

