//Suduko game in 3*3 matrix

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[][] board = {
            {1, 0, 3},
            {0, 2, 0},
            {3, 0, 1}
        };
        while (true) {
            System.out.println("\nCurrent Board:");
            for (int i = 0; i < 3; i++) {
                for (int j = 0; j < 3; j++) {
                    System.out.print(board[i][j] + " ");
                }
                System.out.println();
            }
            System.out.println("\nEnter row (0-2), column (0-2), value (1-3)");
            System.out.println("Enter -1 to quit.");
            int row = sc.nextInt();
            if (row == -1) {
                break;
            }
            int col = sc.nextInt();
            int value = sc.nextInt();
            if (board[row][col] == 0) {
                board[row][col] = value;
            } else {
                System.out.println("Cell is already filled!");
            }
        }
        System.out.println("\nFinal Board:");
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(board[i][j] + " ");
            }
            System.out.println();
        }
    }
}


//Shuffle an element in an array

import java.util.ArrayList;
import java.util.Scanner;
import java.util.Random;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Random rand = new Random();
        ArrayList<Integer> list = new ArrayList<>();
        System.out.print("Enter number of elements: ");
        int n = sc.nextInt();
        System.out.println("Enter the elements:");
        for (int i = 0; i < n; i++) {
            list.add(sc.nextInt());
        }
        for (int k = 1; k <= 5; k++) {
            for (int i = 0; i < list.size(); i++) {
                int j = rand.nextInt(list.size());
                int temp = list.get(i);
                list.set(i, list.get(j));
                list.set(j, temp);
            }
            System.out.println("Shuffle " + k + ": " + list);
        }
    }
}

//Remove an even num in an array


import java.util.ArrayList;
import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Integer> list = new ArrayList<>();
        System.out.print("Enter number of elements: ");
        int n = sc.nextInt();
        System.out.println("Enter the elements:");
        for (int i = 0; i < n; i++) {
            list.add(sc.nextInt());
        }
        for (int i = 0; i < list.size(); i++) {
            if (list.get(i) % 2 == 0) {
                list.remove(i);
                i--; 
            }
        }
        System.out.println("After removing even numbers: " + list);
    }
}


//add,remove,update,addAll


