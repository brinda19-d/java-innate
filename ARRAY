//REPLACE THE GIVEN MATRIX HAVE MISSING NO CHANGE INTO 0

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[][] a = new int[3][3];
        System.out.println("Enter 3 rows:");
        for (int i = 0; i < 3; i++) {
            String line = sc.nextLine().trim();
            String[] s = line.split("\\s+");
            for (int j = 0; j < 3; j++) {
                if (j < s.length)
                    a[i][j] = Integer.parseInt(s[j]);
                else
                    a[i][j] = 0;
            }
        }
        System.out.println("Matrix:");
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(a[i][j] + " ");
            }
            System.out.println();
        }
    }
}
